{
  "name": "@aidoris/kineti-ui",
  "version": "0.0.1",
  "type": "module",
  "author": "Pranav Sukumara Kurup <pranavs.nkm@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aidoris/kineti.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/aidoris/kineti#readme",
  "bugs": {
    "url": "https://github.com/aidoris/kineti/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "README.md",
    "src"
  ],
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "catalog:",
    "@fontsource-variable/jetbrains-mono": "catalog:",
    "@phosphor-icons/react": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "shadcn": "catalog:",
    "tailwind-merge": "catalog:",
    "tw-animate-css": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@turbo/gen": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@tanstack/eslint-config": "catalog:",
    "eslint": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts"
  }
}
