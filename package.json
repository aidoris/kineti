{
  "name": "@aidoris/kineti-base",
  "version": "0.0.1",
  "author": "Pranav Sukumara Kurup <pranavs.nkm@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aidoris/kineti.git"
  },
  "homepage": "https://github.com/aidoris/kineti#readme",
  "bugs": {
    "url": "https://github.com/aidoris/kineti/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "setup:git-hooks:config": "git config core.hooksPath .githooks",
    "setup:git-hooks:chmod": "shx chmod +x .githooks/*",
    "setup:git-hooks": "run-s setup:git-hooks:config setup:git-hooks:chmod",
    "postinstall": "bun run setup:git-hooks"
  },
  "devDependencies": {
    "npm-run-all": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:",
    "shx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20"
  },
  "workspaces": {
    "packages": ["apps/*", "packages/*"],
    "catalog": {
      "@base-ui/react": "^1.5.0",
      "@fontsource-variable/jetbrains-mono": "^5.2.8",
      "@phosphor-icons/react": "^2.1.10",
      "@tailwindcss/vite": "^4.1.18",
      "@tanstack/eslint-config": "^0.3.0",
      "@tanstack/react-router": "^1.132.0",
      "@tanstack/react-start": "^1.132.0",
      "@tanstack/router-plugin": "^1.132.0",
      "@turbo/gen": "^2.8.1",
      "@types/node": "^25.1.0",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^5.1.1",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "commander": "^14.0.3",
      "drizzle-kit": "^0.31.10",
      "drizzle-orm": "^0.45.2",
      "postgres": "^3.4.9",
      "eslint": "^9.39.2",
      "nitro": "latest",
      "npm-run-all": "^4.1.5",
      "prettier": "^3.8.1",
      "prettier-plugin-tailwindcss": "^0.7.2",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "shadcn": "^4.8.0",
      "shx": "^0.4.0",
      "tailwind-merge": "^3.6.0",
      "tailwindcss": "^4.1.18",
      "tsup": "^8.5.1",
      "turbo": "^2.8.17",
      "tw-animate-css": "^1.4.0",
      "typescript": "5.9.3",
      "vite": "^7.3.2",
      "vite-tsconfig-paths": "^5.1.4",
      "zod": "^3.25.76",
      "@better-auth/cli": "^1.4.22",
      "@better-auth/drizzle-adapter": "^1.6.11",
      "better-auth": "^1.6.11",
      "@inlang/paraglide-js": "^2.4.0"
    }
