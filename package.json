{
  "name": "@aidoris/kineti-base",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "setup:git-hooks:config": "git config core.hooksPath .githooks",
    "setup:git-hooks:chmod": "shx chmod +x .githooks/*",
    "setup:git-hooks": "run-s setup:git-hooks:config setup:git-hooks:chmod",
    "postinstall": "bun run setup:git-hooks"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shx": "^0.4.0",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
