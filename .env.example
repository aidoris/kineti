# GitHub Packages npm registry — https://npm.pkg.github.com
# Scoped @aidoris/* packages (see .npmrc)
#
# Option A — use GitHub CLI (if logged in with package scopes):
#   NPM_TOKEN=$(gh auth token)
#
# Option B — create a Personal Access Token:
#   https://github.com/settings/tokens
#
#   Classic token scopes:
#     • write:packages
#     • read:packages
#     • repo (required if the repository is private)
#
#   Fine-grained token:
#     • Repository access: aidoris/kineti (and org packages as needed)
#     • Permissions → Packages: Read and write
#
# Copy this file to .env (gitignored) and set your token:
NPM_TOKEN=github_pat_or_gho_your_token_here
