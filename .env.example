# PostgreSQL — used by @aidoris/kineti-db (drizzle-kit / migrations)
# Loaded from this file in `vite dev` (envDir) and `bun run start` in apps/web.
# For `node .output/server/index.mjs`, use: node --env-file=../../.env …
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kineti

# Better Auth — used by @aidoris/kineti-auth
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
